{
  "name": "hiro",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @hiro/web",
    "dev:mobile": "npm run dev --workspace @hiro/mobile",
    "mobile:reset": "node scripts/mobile-orbital-reset.mjs",
    "lint": "node scripts/lint.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "test": "node scripts/test.mjs",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:governance": "node scripts/check-governance.mjs",
    "check:pr-governance": "node scripts/check-pr-governance.mjs",
    "check:expo-root-artifacts": "node scripts/check-expo-root-artifacts.mjs",
    "check:mobile-runtime": "node scripts/check-mobile-runtime.mjs",
    "check": "node scripts/check.mjs",
    "pr:prepare": "node scripts/prepare-pr-body.mjs --out /tmp/pr_body.md",
    "pr:validate": "node scripts/check-pr-governance.mjs",
    "pr:create": "node scripts/create-pr.mjs"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@hiro/domain": ["packages/domain/src/index.ts"],
      "@hiro/ui-tokens": ["packages/ui-tokens/src/index.ts"],
      "@hiro/ui-primitives": ["packages/ui-primitives/src/index.ts"],
      "@hiro/runtime": ["packages/runtime/src/index.ts"],
      "@hiro/supabase-clients": ["packages/supabase-clients/src/index.ts"]
    }
  }
}
